---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

const keyBenefits = [
  {
    title: "Zero Risk, Cancel Anytime",
    copy: "30-day rolling contract — no lock-ins. We hit your ROI targets and stay because results retain relationships, not contracts."
  },
  {
    title: "Senior-Only Access",
    copy: "Partner exclusively with experienced AI leaders. No junior teams, no service desks — enterprise-level strategy at SME pricing."
  },
  {
    title: "Hands-Off & Futureproof",
    copy: "Zero technical knowledge needed. We build, deploy, train, and maintain your systems while keeping you ahead as AI evolves."
  }
];

const roadmap = [
  {
    title: "Baseline Assessment",
    copy: "Review of current systems and constraints."
  },
  {
    title: "Strategic Direction",
    copy: "Prioritized plan aligned to your goals."
  },
  {
    title: "Implementation",
    copy: "Build and integrate with minimal disruption."
  },
  {
    title: "Go-Live & Optimization",
    copy: "Launch, monitor, and refine for impact."
  },
  {
    title: "On Demand Support",
    copy: "Ongoing oversight and strategic guidance to ensure continued revenue growth."
  }
];

const circleSteps = roadmap.map((step, i) => {
  const angleDeg = -90 + i * 72;
  const angleRad = angleDeg * Math.PI / 180;
  const r = 28;
  return {
    ...step,
    dotX: +(50 + r * Math.cos(angleRad)).toFixed(1),
    dotY: +(50 + r * Math.sin(angleRad)).toFixed(1),
    idx: i
  };
});

const expertise = [
  {
    title: "Agents/Conversational AI",
    copy: "Faster first response, stronger qualification, higher booking momentum and conversion rates.",
    icon: "lightning"
  },
  {
    title: "Automation",
    copy: "Lower manual load through practical workflow and process automation. Increased output per unit of time.",
    icon: "cog"
  },
  {
    title: "Operational Clarity",
    copy: "Cleaner reporting, aligned KPIs, and sharper leadership decisions.",
    icon: "chart"
  },
  {
    title: "Done For You Marketing & Lead Generation",
    copy: "The latest martech provides industry leading CAC, CPL and ROAS.",
    icon: "megaphone"
  }
];

const deliveryFlow = [
  {
    title: "Diagnose",
    copy: "We identify the highest-value AI opportunities based on your commercial goals."
  },
  {
    title: "Deploy",
    copy: "We simply add a layer to your existing setup, so you can carry on doing what you do best with zero disruption."
  },
  {
    title: "Optimize",
    copy: "We monitor, improve, and guide strategy for continuous revenue growth. Ongoing optimisation keeps you ahead of the competition."
  }
];
---

<Layout title="Services" description="Conversational AI, automation, operational clarity, and done-for-you marketing — deployed by senior specialists with zero disruption." visioptPid={169}>
  <!-- Hero — light background, two-column layout -->
  <section class="services-hero-section relative overflow-hidden">
    <!-- Accent line along top edge -->
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-yellow via-blue to-green pointer-events-none" aria-hidden="true"></div>

    <Container>
      <div class="services-hero-grid relative z-10">
        <!-- Left: heading + subheading -->
        <div class="services-hero-left">
          <h1 class="services-hero-title text-navy-light font-bold animate-fade-in-up">
            Your Own AI Multidisciplinary Team, On Demand
          </h1>
          <div class="space-y-4 mt-6">
            <p class="services-hero-sub text-navy/70 font-bold animate-fade-in-up delay-100">
              HumTech builds, implements, maintains and optimises your custom AI Revenue Engine&trade;
            </p>
          </div>
        </div>

        <!-- Right: Trustpilot review -->
        <div class="services-hero-right">
          <div class="tp-review animate-fade-in-up delay-200">
            <div class="tp-review-body">
              <p class="tp-review-text">"Extremely helpful, proactive and communication was excellent throughout. Big thanks to Callum for his help"</p>
              <div class="tp-review-stars">
                <svg viewBox="0 0 24 24" class="tp-review-star"><path d="M12 0l3.09 6.26L22 7.27l-5 4.87 1.18 6.88L12 15.4l-6.18 3.62L7 12.14 2 7.27l6.91-1.01z" fill="#fff"/></svg>
                <svg viewBox="0 0 24 24" class="tp-review-star"><path d="M12 0l3.09 6.26L22 7.27l-5 4.87 1.18 6.88L12 15.4l-6.18 3.62L7 12.14 2 7.27l6.91-1.01z" fill="#fff"/></svg>
                <svg viewBox="0 0 24 24" class="tp-review-star"><path d="M12 0l3.09 6.26L22 7.27l-5 4.87 1.18 6.88L12 15.4l-6.18 3.62L7 12.14 2 7.27l6.91-1.01z" fill="#fff"/></svg>
                <svg viewBox="0 0 24 24" class="tp-review-star"><path d="M12 0l3.09 6.26L22 7.27l-5 4.87 1.18 6.88L12 15.4l-6.18 3.62L7 12.14 2 7.27l6.91-1.01z" fill="#fff"/></svg>
                <svg viewBox="0 0 24 24" class="tp-review-star"><path d="M12 0l3.09 6.26L22 7.27l-5 4.87 1.18 6.88L12 15.4l-6.18 3.62L7 12.14 2 7.27l6.91-1.01z" fill="#fff"/></svg>
              </div>
              <span class="tp-review-author">by JossMan</span>
            </div>
            <div class="tp-review-footer">
              <span class="tp-review-rating">Rated 4.9 / 5 | 245 reviews</span>
              <span class="tp-logo">
                <svg class="tp-logo-star" viewBox="0 0 24 24" fill="none"><polygon points="12,1.5 15.1,8.3 22.5,9.2 17.2,14.1 18.5,21.5 12,17.8 5.5,21.5 6.8,14.1 1.5,9.2 8.9,8.3" fill="#00b67a"/></svg>
                Trustpilot
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Diagnose / Deploy / Optimise — horizontal flow -->
      <div class="delivery-flow">
        {deliveryFlow.map((step, idx) => (
          <>
            <article class="delivery-portrait-card delivery-flow-card">
              <div class="delivery-portrait-badge">{idx + 1}</div>
              <div>
                <h3 class="text-navy font-bold text-lg">{step.title}</h3>
                <p class="text-navy/55 text-sm leading-relaxed mt-1">{step.copy}</p>
              </div>
            </article>
            {idx < deliveryFlow.length - 1 && (
              <div class="delivery-flow-arrow" aria-hidden="true">
                <svg viewBox="0 0 40 24" fill="none" class="w-8 h-6">
                  <path d="M0 12h32m0 0l-8-8m8 8l-8 8" stroke="rgba(6,21,40,0.2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            )}
          </>
        ))}
      </div>
    </Container>
  </section>

  <section class="bg-navy-light py-8 lg:py-10">
    <Container>
      <div class="deploy-layout">
        <!-- Left column: quote + animation -->
        <div class="deploy-left">
          <blockquote class="deploy-quote">
            <p>"Companies that will succeed will be the ones that most effectively use Artificial Intelligence. If you are making maximum use of AI and are competing against someone who is not, you will win."</p>
            <cite>Elon Musk</cite>
          </blockquote>
          <div class="nn-network">
            <svg class="nn-svg" viewBox="0 0 600 500" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                <!-- Background tissue lines -->
                <g class="nn-tissue" opacity="0.06">
                  <line x1="45" y1="65" x2="150" y2="35" stroke="#3DB2DD" stroke-width="0.5"/>
                  <line x1="150" y1="35" x2="280" y2="30" stroke="#D8B743" stroke-width="0.5"/>
                  <line x1="280" y1="30" x2="520" y2="55" stroke="#6BB790" stroke-width="0.5"/>
                  <line x1="40" y1="300" x2="100" y2="440" stroke="#D8B743" stroke-width="0.5"/>
                  <line x1="300" y1="480" x2="450" y2="460" stroke="#3DB2DD" stroke-width="0.5"/>
                  <line x1="450" y1="460" x2="530" y2="400" stroke="#6BB790" stroke-width="0.5"/>
                  <line x1="560" y1="200" x2="530" y2="400" stroke="#3DB2DD" stroke-width="0.5"/>
                </g>
                <!-- Background nodes -->
                <circle cx="45" cy="65" r="3" fill="#3DB2DD" opacity="0.15"><animate attributeName="opacity" values="0.1;0.25;0.1" dur="4s" repeatCount="indefinite"/></circle>
                <circle cx="150" cy="35" r="2.5" fill="#D8B743" opacity="0.12"><animate attributeName="opacity" values="0.08;0.2;0.08" dur="5s" repeatCount="indefinite"/></circle>
                <circle cx="520" cy="55" r="3" fill="#6BB790" opacity="0.15"><animate attributeName="opacity" values="0.1;0.25;0.1" dur="4.5s" repeatCount="indefinite"/></circle>
                <circle cx="560" cy="200" r="2.5" fill="#3DB2DD" opacity="0.12"><animate attributeName="opacity" values="0.08;0.2;0.08" dur="5.5s" repeatCount="indefinite"/></circle>
                <circle cx="40" cy="300" r="2.5" fill="#D8B743" opacity="0.12"><animate attributeName="opacity" values="0.08;0.2;0.08" dur="4s" repeatCount="indefinite"/></circle>
                <circle cx="300" cy="480" r="3" fill="#3DB2DD" opacity="0.15"><animate attributeName="opacity" values="0.1;0.25;0.1" dur="6s" repeatCount="indefinite"/></circle>
                <circle cx="530" cy="400" r="2.5" fill="#6BB790" opacity="0.12"><animate attributeName="opacity" values="0.08;0.2;0.08" dur="5s" repeatCount="indefinite"/></circle>
                <circle cx="100" cy="440" r="2" fill="#D8B743" opacity="0.1"><animate attributeName="opacity" values="0.06;0.18;0.06" dur="4.5s" repeatCount="indefinite"/></circle>
                <circle cx="450" cy="460" r="2.5" fill="#3DB2DD" opacity="0.12"><animate attributeName="opacity" values="0.08;0.2;0.08" dur="5.5s" repeatCount="indefinite"/></circle>
                <circle cx="280" cy="30" r="2" fill="#6BB790" opacity="0.1"><animate attributeName="opacity" values="0.06;0.18;0.06" dur="6s" repeatCount="indefinite"/></circle>

                <!-- Hero-to-hero connection paths (drawn via CSS stroke-dashoffset) -->
                <path id="conn-h1h2" d="M300,80 C220,130 150,190 120,250" class="nn-conn nn-conn-1" fill="none" stroke="#D8B743" stroke-width="1.5" stroke-linecap="round"/>
                <path id="conn-h1h3" d="M300,80 C380,130 450,190 480,250" class="nn-conn nn-conn-1" fill="none" stroke="#D8B743" stroke-width="1.5" stroke-linecap="round"/>
                <path id="conn-h2h3" d="M120,250 C200,220 400,220 480,250" class="nn-conn nn-conn-2" fill="none" stroke="#3DB2DD" stroke-width="1.5" stroke-linecap="round"/>
                <path id="conn-h2h4" d="M120,250 C150,320 220,380 300,420" class="nn-conn nn-conn-3" fill="none" stroke="#6BB790" stroke-width="1.5" stroke-linecap="round"/>
                <path id="conn-h3h4" d="M480,250 C450,320 380,380 300,420" class="nn-conn nn-conn-4" fill="none" stroke="#D8B743" stroke-width="1.5" stroke-linecap="round"/>
                <path id="conn-h1h4" d="M300,80 C300,180 300,320 300,420" class="nn-conn nn-conn-2" fill="none" stroke="#3DB2DD" stroke-width="1.5" stroke-linecap="round"/>

                <!-- Dendrite connections (hero to background) -->
                <path d="M300,80 Q225,50 150,35" class="nn-conn nn-conn-1 nn-dendrite" fill="none" stroke="#D8B743" stroke-width="0.8" stroke-linecap="round"/>
                <path d="M300,80 L280,30" class="nn-conn nn-conn-1 nn-dendrite" fill="none" stroke="#D8B743" stroke-width="0.8" stroke-linecap="round"/>
                <path d="M120,250 Q70,160 45,65" class="nn-conn nn-conn-2 nn-dendrite" fill="none" stroke="#3DB2DD" stroke-width="0.8" stroke-linecap="round"/>
                <path d="M120,250 Q80,280 40,300" class="nn-conn nn-conn-2 nn-dendrite" fill="none" stroke="#3DB2DD" stroke-width="0.8" stroke-linecap="round"/>
                <path d="M480,250 Q510,150 520,55" class="nn-conn nn-conn-3 nn-dendrite" fill="none" stroke="#6BB790" stroke-width="0.8" stroke-linecap="round"/>
                <path d="M480,250 Q520,220 560,200" class="nn-conn nn-conn-3 nn-dendrite" fill="none" stroke="#6BB790" stroke-width="0.8" stroke-linecap="round"/>
                <path d="M300,420 L300,480" class="nn-conn nn-conn-4 nn-dendrite" fill="none" stroke="#D8B743" stroke-width="0.8" stroke-linecap="round"/>

                <!-- Synapse pulse dots along connections -->
                <!-- Phase 1 pulses (h1→h2, h1→h3) -->
                <circle cx="260" cy="105" r="2" fill="#D8B743" class="nn-pulse nn-pulse-1"/>
                <circle cx="200" cy="160" r="2" fill="#D8B743" class="nn-pulse nn-pulse-1 nn-pulse-d1"/>
                <circle cx="340" cy="105" r="2" fill="#D8B743" class="nn-pulse nn-pulse-1 nn-pulse-d2"/>
                <circle cx="410" cy="160" r="2" fill="#D8B743" class="nn-pulse nn-pulse-1 nn-pulse-d3"/>
                <!-- Phase 2 pulses (h2↔h3, h1→h4) -->
                <circle cx="200" cy="230" r="2" fill="#3DB2DD" class="nn-pulse nn-pulse-2"/>
                <circle cx="300" cy="220" r="2" fill="#3DB2DD" class="nn-pulse nn-pulse-2 nn-pulse-d1"/>
                <circle cx="400" cy="230" r="2" fill="#3DB2DD" class="nn-pulse nn-pulse-2 nn-pulse-d2"/>
                <circle cx="300" cy="180" r="2" fill="#3DB2DD" class="nn-pulse nn-pulse-2 nn-pulse-d3"/>
                <!-- Phase 3 pulses (h2→h4) -->
                <circle cx="140" cy="290" r="2" fill="#6BB790" class="nn-pulse nn-pulse-3"/>
                <circle cx="190" cy="340" r="2" fill="#6BB790" class="nn-pulse nn-pulse-3 nn-pulse-d1"/>
                <circle cx="240" cy="380" r="2" fill="#6BB790" class="nn-pulse nn-pulse-3 nn-pulse-d2"/>
                <!-- Phase 4 pulses (h3→h4) -->
                <circle cx="460" cy="290" r="2" fill="#D8B743" class="nn-pulse nn-pulse-4"/>
                <circle cx="410" cy="340" r="2" fill="#D8B743" class="nn-pulse nn-pulse-4 nn-pulse-d1"/>
                <circle cx="360" cy="380" r="2" fill="#D8B743" class="nn-pulse nn-pulse-4 nn-pulse-d2"/>

                <!-- Full power overlay (flashes at cycle end) -->
                <g class="nn-full-power">
                  <path d="M300,80 C220,130 150,190 120,250" stroke="#D8B743" stroke-width="3" fill="none" opacity="0.6"/>
                  <path d="M300,80 C380,130 450,190 480,250" stroke="#D8B743" stroke-width="3" fill="none" opacity="0.6"/>
                  <path d="M120,250 C200,220 400,220 480,250" stroke="#3DB2DD" stroke-width="3" fill="none" opacity="0.6"/>
                  <path d="M120,250 C150,320 220,380 300,420" stroke="#6BB790" stroke-width="3" fill="none" opacity="0.6"/>
                  <path d="M480,250 C450,320 380,380 300,420" stroke="#D8B743" stroke-width="3" fill="none" opacity="0.6"/>
                  <path d="M300,80 C300,180 300,320 300,420" stroke="#3DB2DD" stroke-width="3" fill="none" opacity="0.6"/>
                  <animate attributeName="opacity" values="0;0;0;0.6;0.9;0.6;0" keyTimes="0;0.84;0.857;0.88;0.9;0.94;1" dur="14s" repeatCount="indefinite"/>
                </g>

                <!-- Hero nodes (scale in via SMIL animate) -->
                <!-- H1: Conversational AI (top, yellow) -->
                <circle cx="300" cy="80" r="0" fill="none" stroke="#D8B743" stroke-width="1" opacity="0">
                  <animate attributeName="r" values="0;0;35;35;35;0" keyTimes="0;0.01;0.043;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;0;0.15;0.15;0;0" keyTimes="0;0.01;0.043;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                </circle>
                <circle cx="300" cy="80" r="0" fill="#D8B743">
                  <animate attributeName="r" values="0;0;18;18;18;0" keyTimes="0;0.001;0.029;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.001;0.029;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                </circle>
                <g opacity="0"><animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.036;0.071;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <path d="M296,74 L296,70 L291,78 L296,78 L296,84 L301,76 L296,76 Z" fill="#061528" stroke="none"/>
                </g>

                <!-- H2: Automation (left, blue) -->
                <circle cx="120" cy="250" r="0" fill="none" stroke="#3DB2DD" stroke-width="1" opacity="0">
                  <animate attributeName="r" values="0;0;35;35;35;0" keyTimes="0;0.214;0.257;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;0;0.15;0.15;0;0" keyTimes="0;0.214;0.257;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                </circle>
                <circle cx="120" cy="250" r="0" fill="#3DB2DD">
                  <animate attributeName="r" values="0;0;18;18;18;0" keyTimes="0;0.214;0.243;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.214;0.243;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                </circle>
                <g opacity="0"><animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.25;0.286;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <circle cx="120" cy="250" r="5" fill="none" stroke="#061528" stroke-width="1.5"/>
                  <circle cx="120" cy="250" r="2" fill="none" stroke="#061528" stroke-width="1"/>
                </g>

                <!-- H3: Operational Clarity (right, green) -->
                <circle cx="480" cy="250" r="0" fill="none" stroke="#6BB790" stroke-width="1" opacity="0">
                  <animate attributeName="r" values="0;0;35;35;35;0" keyTimes="0;0.429;0.471;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;0;0.15;0.15;0;0" keyTimes="0;0.429;0.471;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                </circle>
                <circle cx="480" cy="250" r="0" fill="#6BB790">
                  <animate attributeName="r" values="0;0;18;18;18;0" keyTimes="0;0.429;0.457;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.429;0.457;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                </circle>
                <g opacity="0"><animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.464;0.5;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <rect x="474" y="244" width="4" height="10" rx="1" fill="#061528"/>
                  <rect x="480" y="240" width="4" height="14" rx="1" fill="#061528"/>
                  <rect x="486" y="247" width="4" height="7" rx="1" fill="#061528"/>
                </g>

                <!-- H4: Marketing (bottom, yellow) -->
                <circle cx="300" cy="420" r="0" fill="none" stroke="#D8B743" stroke-width="1" opacity="0">
                  <animate attributeName="r" values="0;0;35;35;35;0" keyTimes="0;0.643;0.686;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;0;0.15;0.15;0;0" keyTimes="0;0.643;0.686;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                </circle>
                <circle cx="300" cy="420" r="0" fill="#D8B743">
                  <animate attributeName="r" values="0;0;18;18;18;0" keyTimes="0;0.643;0.671;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.643;0.671;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                </circle>
                <g opacity="0"><animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.679;0.714;0.857;0.95;1" dur="14s" repeatCount="indefinite"/>
                  <path d="M296,415 L296,425 C296,426 295,426 295,425 L293,419 M305,420 C306.5,420 306.5,417 305,417 M293,422 C292,422 291,421 291,420 L291,415 L292,415 C295,415 297,414 298,413 L298,427 C297,426 295,425 292,425 L291,425" fill="none" stroke="#061528" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </g>

                <!-- "REVENUE ENGINE LIVE" label at centre during full power -->
                <text x="300" y="255" text-anchor="middle" fill="#D8B743" font-size="11" font-weight="700" letter-spacing="0.12em" opacity="0">
                  REVENUE ENGINE LIVE
                  <animate attributeName="opacity" values="0;0;0;0.9;0.9;0;0" keyTimes="0;0.84;0.88;0.9;0.93;0.96;1" dur="14s" repeatCount="indefinite"/>
                </text>
              </svg>
          </div>
        </div>

        <!-- Right column: heading + cards -->
        <div class="deploy-right">
          <h2 class="deploy-heading">Typical Deployments</h2>
          <div class="nn-cards">
              <div class="nn-card nn-card-1">
                <div class="nn-card-accent" style="background:#D8B743"></div>
                <div class="nn-card-icon" style="background:rgba(216,183,67,0.12)">
                  <svg class="w-8 h-8 text-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                </div>
                <h3 class="text-yellow font-bold text-xl mb-3">Agents/Conversational AI</h3>
                <p class="text-white/70 text-base leading-relaxed">Faster first response, stronger qualification, higher booking momentum and conversion rates.</p>
              </div>
              <div class="nn-card nn-card-2">
                <div class="nn-card-accent" style="background:#3DB2DD"></div>
